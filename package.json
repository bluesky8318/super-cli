{
  "name": "super-cli",
  "version": "0.1.0",
  "description": "Claude Code session management CLI tool",
  "type": "module",
  "bin": {
    "super-cli": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "pnpm build:cli && pnpm build:web",
    "build:cli": "tsup",
    "build:web": "vite build --config src/web/vite.config.ts",
    "dev": "tsup --watch",
    "dev:web": "vite dev --config src/web/vite.config.ts",
    "test": "vitest",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["claude", "claude-code", "session", "cli", "manager"],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fastify": "^5.3.3",
    "@fastify/static": "^8.1.0",
    "@fastify/cors": "^11.0.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "globby": "^14.1.0",
    "date-fns": "^4.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsup": "^8.5.0",
    "@types/node": "^22.15.0",
    "vitest": "^3.2.1",
    "vite": "^6.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "postcss": "^8.5.3",
    "autoprefixer": "^10.4.21"
  }
}
